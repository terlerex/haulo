# --- Serveur ---
PORT=3001
NODE_ENV=development

# SESSION_SECRET : obligatoire en prod (le serveur refuse de démarrer sans).
# Générer avec : openssl rand -hex 32
SESSION_SECRET=change_this_to_a_random_64_char_string

# CORS : URL exacte du front (sans slash final). En prod, ton domaine.
CORS_ORIGIN=http://localhost:5173

# Chemins. Sur Railway, monter un Volume sur /server/uploads (sinon éphémère).
DB_PATH=./db.sqlite
UPLOADS_DIR=./server/uploads

# --- Postgres (optionnel, futur) ---
# Quand défini, le code basculera vers un pool `pg` plutôt que SQLite.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
